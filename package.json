{
  "name": "financial-intelligence-monitor",
  "version": "1.0.0",
  "description": "Interactive corruption (CPI 2024), FATF AML risk and live financial-crime monitoring dashboard.",
  "main": "electron/main.js",
  "author": {
    "name": "kvcodeproject",
    "url": "https://github.com/kvcodeproject"
  },
  "license": "MIT",
  "private": true,
  "homepage": "https://github.com/kvcodeproject/Financial-Intelligence-Monitor",
  "repository": {
    "type": "git",
    "url": "https://github.com/kvcodeproject/Financial-Intelligence-Monitor.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "release": "electron-builder --publish always"
  },
  "devDependencies": {
    "electron": "^31.3.1",
    "electron-builder": "^25.0.5"
  },
  "build": {
    "appId": "com.kvcodeproject.fim",
    "productName": "Financial Intelligence Monitor",
    "copyright": "Copyright © 2026 kvcodeproject",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "index.html",
      "styles.css",
      "data.js",
      "risk-data.js",
      "gti-data.js",
      "sanctions-data.js",
      "crime-data.js",
      "app.js",
      "crime.js",
      "kpi.js",
      "status-bar.js",
      "modal.js",
      "metrics.js",
      "submit.js",
      "share.js",
      "export.js",
      "csv.js",
      "audit.js",
      "risk-score.js",
      "watchlist.js",
      "electron/**/*",
      "!**/.DS_Store",
      "!**/*.map"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "artifactName": "Financial-Intelligence-Monitor-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FIM"
    },
    "portable": {
      "artifactName": "Financial-Intelligence-Monitor-Portable-${version}.${ext}"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.finance",
      "artifactName": "Financial-Intelligence-Monitor-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "Office",
      "artifactName": "Financial-Intelligence-Monitor-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "kvcodeproject",
        "repo": "Financial-Intelligence-Monitor"
      }
    ]
  }
}
